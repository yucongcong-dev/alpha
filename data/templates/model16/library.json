{
  "_comment": "model16 独立模板库 — 去双重中性化、删hump/无效算子、bucket加densify、增ratio/pair、增group_backfill预处理、增ts_quantile/normalize、增长窗口504、增derivative反转模板",
  "_comment_placeholders": "{field}=字段名, {field_preprocessed}=winsorize(ts_backfill({field}, {backfill_window}), std=4), {field_groupfill}=group_backfill({field}, subindustry, 252, std=4), {backfill_window}=settings.yaml expression.backfill_window",
  "_dataset_id": "model16",
  "default": [
    {
      "name": "model16_group_zscore_sector_120",
      "expression": "group_rank(ts_zscore({field_groupfill}, 120), sector)",
      "priority": 1000,
      "family": "group_zscore",
      "layer": "group",
      "field_tags": ["model16_sparse_fscore", "model16_sparse_bfl"],
      "dataset_tags": ["model16", "fundamental_scores"]
    },
    {
      "name": "model16_bucket_cap_ratio_zscore_120",
